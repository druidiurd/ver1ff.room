/.angular/cache
.sass-cache/
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings
__screenshots__/

# System files
.DS_Store
Thumbs.db

# Environment / secrets
.env
*.env
api/.env

# Local tools
psb-tools/

# Python cache
__pycache__/
*.pyc
*.pyo

# Local manuals (working materials, not part of deploy)
manuals/

# Photoshop source files and renders
*.psb
*.psd
